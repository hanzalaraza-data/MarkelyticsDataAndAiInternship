    {
      "cell_type": "code",
      "source": [
        "def detect_issue(row):\n",
        "    if row[\"Check_In\"] == \"00:00\":\n",
        "        return \"Missing Check-In\"\n",
        "    elif row[\"Source\"] == \"Manual\":\n",
        "        return \"Manual Entry\"\n",
        "    elif row[\"Check_In_Minutes\"] > 600:\n",
        "        return \"Late دخول\"\n",
        "    else:\n",
        "        return \"OK\"\n",
        "\n",
        "df[\"Issue\"] = df.apply(detect_issue, axis=1)"
      ],
      "metadata": {
        "id": "H9nb7xVoVxh3"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.ensemble import IsolationForest\n",
        "\n",
        "model = IsolationForest(contamination=0.2, random_state=42)\n",
        "df[\"Anomaly\"] = model.fit_predict(df[[\"Check_In_Minutes\"]])\n",
        "\n",
        "df[\"Anomaly\"] = df[\"Anomaly\"].map({1: \"Normal\", -1: \"Anomaly\"})\n"
      ],
