    },
    {
      "cell_type": "code",
      "source": [
        "# Convert Date\n",
        "df[\"Date\"] = pd.to_datetime(df[\"Date\"])\n",
        "\n",
        "# Handle missing Check_In\n",
        "df[\"Check_In\"] = df[\"Check_In\"].fillna(\"00:00\")\n",
        "\n",
        "# Convert time to minutes\n",
        "def time_to_minutes(t):\n",
        "    h, m = map(int, t.split(\":\"))\n",
        "    return h*60 + m\n",
        "\n",
        "df[\"Check_In_Minutes\"] = df[\"Check_In\"].apply(time_to_minutes)\n",
        "\n",
        "print(\"\\nCleaned Data:\")\n",
        "print(df)"
      ],
      "metadata": {
