      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Sample attendance dataset\n",
        "data = {\n",
        "    \"Employee_ID\": [101, 101, 102, 102, 103, 103],\n",
        "    \"Date\": [\"2026-04-01\", \"2026-04-02\", \"2026-04-01\", \"2026-04-02\", \"2026-04-01\", \"2026-04-02\"],\n",
        "    \"Check_In\": [\"09:05\", None, \"09:00\", \"11:30\", None, \"09:10\"],\n",
        "    \"Source\": [\"Biometric\", \"Manual\", \"Biometric\", \"Manual\", \"Manual\", \"Biometric\"]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(\"Raw Data:\")\n",
        "print(df)"
      ],
      "metadata": {
